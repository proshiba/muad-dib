          "informationUri": "https://github.com/DNSZLSK/muad-dib",
          "rules": [
            {
              "id": "MUADDIB-AST-001",
              "name": "Sensitive String Reference",
              "shortDescription": {
                "text": "Reference a un chemin ou identifiant sensible (.npmrc, .ssh, tokens)"
              },
              "fullDescription": {
                "text": "Reference a un chemin ou identifiant sensible (.npmrc, .ssh, tokens)"
