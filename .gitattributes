# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly mark source files
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gz binary
*.tgz binary
*.wasm binary
